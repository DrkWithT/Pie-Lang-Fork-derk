.: Pie Fold Expressions - requires infix + operator to be defined first

infix + = (a, b) => __builtin_add(a, b);

.: Unary left fold: (((1 + 2) + 3) + 4)
sumLeft = (pack: ...Any) => (pack + ...);
__builtin_print("unary left fold =", sumLeft(1, 2, 3, 4));

.: Unary right fold: (1 + (2 + (3 + 4)))
sumRight = (pack: ...Any) => (... + pack);
__builtin_print("unary right fold =", sumRight(1, 2, 3, 4));

.: Binary left fold with initial value: ((((10 + 1) + 2) + 3) + 4)
init = 10;
sumBinLeft = (pack: ...Any) => (init + pack + ...);
__builtin_print("binary left fold =", sumBinLeft(1, 2, 3, 4));

.: Binary right fold with initial value: (1 + (2 + (3 + (4 + 10))))
sumBinRight = (pack: ...Any) => (... + pack + init);
__builtin_print("binary right fold =", sumBinRight(1, 2, 3, 4));

.: Binary fold with empty pack yields initial value
sumEmpty = (pack: ...Any) => (init + pack + ...);
__builtin_print("empty pack fold =", sumEmpty());
